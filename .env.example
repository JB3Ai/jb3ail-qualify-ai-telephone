# ── Twilio Config ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# ── Domain (used to build Twilio webhook URLs) ─────────────────────────────────
# Production (Fly.io primary):
DOMAIN=jb3ail-qualify-ai-telephone.fly.dev
# Local dev with ngrok:
# PUBLIC_DOMAIN=your-ngrok-subdomain.ngrok-free.app

# ── Frontend backend URL (Vite build-time) ─────────────────────────────────────
VITE_BACKEND_URL=https://jb3ail-qualify-ai-telephone.fly.dev

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key

# ── Microsoft Azure Speech Service ────────────────────────────────────────────
SPEECH_KEY=your_azure_speech_key
SPEECH_REGION=southafricanorth
AZURE_STT_ENDPOINT=https://southafricanorth.stt.speech.microsoft.com
AZURE_TTS_ENDPOINT=https://southafricanorth.tts.speech.microsoft.com
# Extended region for voices not available in southafricanorth (xh-ZA, nso-ZA).
# Create a second Azure Speech resource in e.g. westeurope and set these.
# SPEECH_KEY_EXTENDED=your_secondary_speech_key
# SPEECH_REGION_EXTENDED=westeurope

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_REGION=swedencentral

# ── Google Sheets Intelligence Ledger ─────────────────────────────────────────
SPREADSHEET_ID=your_google_spreadsheet_id
GAS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
GOOGLE_KEY_JSON_DATA={"type":"service_account",...}

# ── Azure Application Insights (optional) ─────────────────────────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
